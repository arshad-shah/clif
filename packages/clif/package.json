{
  "name": "clif",
  "version": "1.0.0",
  "description": "Tiny, zero-dependency CLI framework with beautiful output and composable API",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./prompts": {
      "import": {
        "types": "./dist/prompts.d.mts",
        "default": "./dist/prompts.mjs"
      },
      "require": {
        "types": "./dist/prompts.d.cts",
        "default": "./dist/prompts.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm run build && pnpm run test"
  },
  "keywords": [
    "cli",
    "terminal",
    "framework",
    "prompts",
    "colors",
    "spinner",
    "progress",
    "zero-dependency",
    "tty",
    "chalk",
    "commander",
    "inquirer",
    "ora"
  ],
  "author": "Arshad Shah",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/arshad-shah/clif.git",
    "directory": "packages/clif"
  },
  "bugs": {
    "url": "https://github.com/arshad-shah/clif/issues"
  },
  "homepage": "https://github.com/arshad-shah/clif#readme",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsdown": "^0.20.3",
    "typescript": "^5.8.0",
    "vitest": "^4.1.6"
  },
  "engines": {
    "node": ">=22.12.0"
  }
}
