{
  "printWidth": 100,
  "tabWidth": 2,
  "useTabs": false,
  "semi": true,
  "singleQuote": false,
  "trailingComma": "all",
  "endOfLine": "lf",
  "proseWrap": "preserve",
  "overrides": [
    {
      "files": ["*.md", "*.mdx"],
      "options": { "printWidth": 80 }
    },
    {
      "files": ["*.yaml", "*.yml"],
      "options": { "singleQuote": false }
    }
  ]
}
